rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Admin estricto (para acciones sensibles de escritura global).
    function isAdmin() {
      return request.auth != null && (
        request.auth.token.admin == true ||
        request.auth.token.role == 'admin' ||
        (
          exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'
        )
      );
    }

    // Roles internos con acceso al panel (admin + empleados operativos).
    function isStaff() {
      return request.auth != null && (
        request.auth.token.role == 'admin' ||
        request.auth.token.role == 'peluqueria' ||
        request.auth.token.role == 'transporte' ||
        (
          exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
          (
            get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
            get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'peluqueria' ||
            get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'transporte'
          )
        )
      );
    }

    // --- USER DATA ---
    match /users/{userId} {
      // Staff puede leer fichas para operar, pero solo dueño/admin pueden modificar usuario.
      allow read: if request.auth.uid == userId || isStaff();
      allow update: if request.auth.uid == userId || isAdmin();
      allow create: if request.auth != null;

      // Subcollection: MASCOTAS
      match /mascotas/{mascotaId} {
        // Staff puede consultar fichas clínicas; escritura solo dueño/admin.
        allow get, list: if request.auth.uid == userId || isStaff();
        allow create, update, delete: if request.auth.uid == userId || isAdmin();

        match /turnos/{turnoId} {
          allow read: if request.auth.uid == userId || isStaff();
          allow write: if request.auth.uid == userId || isAdmin();

          match /medicamentos/{medicamentoId} {
            allow read: if request.auth.uid == userId || isStaff();
            allow write: if request.auth.uid == userId || isAdmin();
          }
        }

        match /carnetSanitario/{entryId} {
          allow read: if request.auth.uid == userId || isStaff();
          allow write: if request.auth.uid == userId || isAdmin();
        }
      }
    }

    // --- GLOBAL COLLECTIONS ---

    match /servicios/{servicioId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /productos/{productoId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /turnos_peluqueria/{fecha} {
        allow read: if true;
        allow write: if request.auth != null;
    }

    match /configuracion/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
