rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function roleFromToken() {
      return isSignedIn() && request.auth.token.role is string
        ? request.auth.token.role
        : '';
    }

    function roleFromDoc() {
      return isSignedIn() &&
             exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role is string
        ? get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role
        : '';
    }

    function hasRole(role) {
      return roleFromToken() == role || roleFromDoc() == role;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      // Compatibilidad con custom claim legacy + rol moderno.
      return isSignedIn() && (request.auth.token.admin == true || hasRole('admin'));
    }

    function isStaff() {
      return isSignedIn() && (
        hasRole('admin') ||
        hasRole('peluqueria') ||
        hasRole('transporte')
      );
    }

    // --- USERS ---
    match /users/{userId} {
      // Dueño de la cuenta o staff interno pueden leer ficha.
      allow read: if isOwner(userId) || isStaff();

      // Solo dueño/admin pueden modificar perfil de usuario.
      allow create: if isSignedIn();
      allow update, delete: if isOwner(userId) || isAdmin();

      // Mascotas del cliente
      match /mascotas/{mascotaId} {
        // Historia clínica y ficha visibles para dueño/staff.
        allow get, list: if isOwner(userId) || isStaff();

        // Alta/edición/baja de mascota: dueño o admin.
        allow create, update, delete: if isOwner(userId) || isAdmin();

        // Turnos asociados a la mascota
        match /turnos/{turnoId} {
          allow read: if isOwner(userId) || isStaff();
          allow write: if isOwner(userId) || isAdmin();

          match /medicamentos/{medicamentoId} {
            allow read: if isOwner(userId) || isStaff();
            allow write: if isOwner(userId) || isAdmin();
          }
        }

        // Entradas manuales de historia clínica
        match /carnetSanitario/{entryId} {
          allow read: if isOwner(userId) || isStaff();
          allow write: if isOwner(userId) || isAdmin();
        }
      }

      // Compatibilidad con estructura legacy usada en /turnos/page.jsx
      match /turnos/{turnoId} {
        allow read, write: if isOwner(userId) || isAdmin();
      }
    }

    // --- COLECCIONES GLOBALES ---

    // Catálogo de servicios visible a todos.
    match /servicios/{servicioId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Productos visibles a todos.
    match /productos/{productoId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Disponibilidad de peluquería.
    match /turnos_peluqueria/{fecha} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    // Configuración general.
    match /configuracion/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Reserva para potencial colección global legacy de turnos.
    match /turnos/{turnoId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
  }
}
